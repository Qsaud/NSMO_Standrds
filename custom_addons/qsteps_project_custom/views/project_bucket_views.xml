<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_qsteps_project_bucket_tree" model="ir.ui.view">
            <field name="name">qsteps.project.bucket.tree</field>
            <field name="model">qsteps.project.bucket</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="user_id"/>
                    <field name="state"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="active" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_qsteps_project_bucket_search" model="ir.ui.view">
            <field name="name">qsteps.project.bucket.search</field>
            <field name="model">qsteps.project.bucket</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="user_id"/>
                    <filter name="state_active" string="Active" domain="[('state', '=', 'active')]"/>
                    <filter name="state_closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                </search>
            </field>
        </record>

        <record id="view_qsteps_project_bucket_form" model="ir.ui.view">
            <field name="name">qsteps.project.bucket.form</field>
            <field name="model">qsteps.project.bucket</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="partner_id"/>
                                <field name="user_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                        <notebook>
                            <page string="Projects">
                                <field name="project_ids" context="{'default_bucket_id': id}">
                                    <tree>
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="user_id"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_qsteps_project_bucket" model="ir.actions.act_window">
            <field name="name">Project Buckets</field>
            <field name="res_model">qsteps.project.bucket</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_qsteps_project_bucket_search"/>
        </record>

        <menuitem id="menu_qsteps_project_bucket"
                  name="Project Buckets"
                  parent="project.menu_main_pm"
                  action="action_qsteps_project_bucket"
                  sequence="90"
                  groups="project.group_project_user"/>
    </data>
</odoo>
