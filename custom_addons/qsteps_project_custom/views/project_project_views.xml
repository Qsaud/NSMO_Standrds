<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_project_project_form_bucket_inherit" model="ir.ui.view">
            <field name="name">project.project.form.bucket.inherit</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="bucket_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_project_project_tree_bucket_inherit" model="ir.ui.view">
            <field name="name">project.project.tree.bucket.inherit</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project"/>
            <field name="arch" type="xml">
                <xpath expr="//tree/field[@name='name']" position="after">
                    <field name="bucket_id" optional="hide"/>
                </xpath>
            </field>
        </record>

        <record id="view_project_project_filter_bucket_inherit" model="ir.ui.view">
            <field name="name">project.project.search.bucket.inherit</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project_project_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="bucket_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_project_project_search_inherit_subprojects" model="ir.ui.view">
            <field name="name">project.project.search.inherit.subprojects</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project_project_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <separator/>
                    <filter name="root_projects" string="Root Projects" domain="[('parent_id', '=', False)]"/>
                    <filter name="subprojects" string="Subprojects" domain="[('parent_id', '!=', False)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
